{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2020",
		"strict": true,
		"noImplicitReturns": true,
		"moduleResolution": "node",
		"noUncheckedIndexedAccess": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"useUnknownInCatchVariables": true,
		"types": [],
		"lib": [
			"DOM",
			"ES2020"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
