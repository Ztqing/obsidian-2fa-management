{
	"name": "obsidian-2fa-management",
	"version": "1.0.0",
	"description": "A local-first Obsidian plugin for managing encrypted TOTP 2FA codes",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.tests.json --noEmit",
		"build": "npm run typecheck && node esbuild.config.mjs production",
		"test": "npm run typecheck && node --test tests/index.test.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "20.19.37",
		"esbuild": "0.27.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "17.4.0",
		"jiti": "2.6.1",
		"qrcode-generator": "^2.0.4",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.2"
	},
	"dependencies": {
		"jsqr": "^1.4.0",
		"obsidian": "^1.8.7"
	}
}
